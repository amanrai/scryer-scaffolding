# Scryer local harness configuration
# The full 43200-43299 range is permanently reserved for Scryer harness services.

SCRYER_RESERVED_PORT_START=43200
SCRYER_RESERVED_PORT_END=43299

SCRYER_PM_PORT=43210
SCRYER_LOOM_PORT=43211
SCRYER_ORCHESTRATOR_PORT=43212
SCRYER_TMUXER_PORT=43213
SCRYER_VAULT_PORT=43214
SCRYER_INTERACTION_PORT=43215
SCRYER_STT_PORT=43216

SCRYER_PM_HOST=127.0.0.1
SCRYER_LOOM_HOST=127.0.0.1

SCRYER_PM_URL=http://127.0.0.1:43210
SCRYER_LOOM_URL=http://127.0.0.1:43211

SCRYER_COMMON_VOLUME_ROOT=/Users/amanrai/Code/common-volume
SCRYER_PM_APP_DIR=/Users/amanrai/Code/common-volume/repos/pm-system-ui
SCRYER_LOOM_APP_DIR=/Users/amanrai/Code/common-volume/repos/loom

SCRYER_OPEN_BROWSER=1
SCRYER_BROWSER=chrome
SCRYER_SWIFTBAR_AUTOSTART=1
SCRYER_NODE_BIN_DIR=/Users/amanrai/.nvm/versions/node/v22.22.0/bin
